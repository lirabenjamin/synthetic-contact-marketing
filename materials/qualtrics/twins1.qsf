"NextChoiceId":2,"NextAnswerId":3,"Labels":{"1":{"Display":"Democrat"},"2":{"Display":"Republican"}},"QuestionJS":"Qualtrics.SurveyEngine.addOnPageSubmit(function () {\n  var val = parseInt(this.getQuestionInfo().value, 10); \/\/ slider-safe\n\n  Qualtrics.SurveyEngine.setEmbeddedData(\"PartyNumeric\", val);\n\n  if (val < 50) {\n    Qualtrics.SurveyEngine.setEmbeddedData(\"IngroupLabel\", \"Democrat\");\n    Qualtrics.SurveyEngine.setEmbeddedData(\"OutgroupLabel\", \"Republican\");\n  } else {\n    Qualtrics.SurveyEngine.setEmbeddedData(\"IngroupLabel\", \"Republican\");\n    Qualtrics.SurveyEngine.setEmbeddedData(\"OutgroupLabel\", \"Democrat\");\n  }\n});"}},{"SurveyID":"SV_7V5e1i5581koSwu","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Once you click next, you will be redirected to a chatbot that has been prompted to represent ...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center; margin: 20px 0;\">\n  <img\n    src=\"https:\/\/raw.githubusercontent.com\/lirabenjamin\/twins_pilot2\/main\/materials\/qualtrics\/images\/bot.png\"\n    alt=\"bot icon\"\n    style=\"max-width: 500px; width: 100%; height: auto;\"\n  >\n<\/div>\n\n\nOnce you click next, you will be redirected to a chatbot that has been prompted to represent <strong>${e:\/\/Field\/OutgroupLabel}s.<\/strong><br>\n<br>\nPlease have a 10 minute conversation with it. Feel free to ask it or tell it anything.<br>\n<br>\n<strong>Remember:&nbsp;<\/strong>You are trying to understand porduct market fit for a set of electricity saving applicances.<br>\n<br>\nDo not leave the screen.<br>\n<br>\nThe chatbot may take a minute to load.","DefaultChoices":false,"DataExportTag":"Q2","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Once you click next, you will be redirected to a chatbot that has been prompted to represent ...","ChoiceOr