tionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your gender?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Other"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID26"}},{"SurveyID":"SV_7V5e1i5581koSwu","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"What is your age?","TertiaryAttribute":null,"Payload":{"QuestionText":"What is your age?","DefaultChoices":false,"DataExportTag":"age","QuestionID":"QID27","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is your age?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"18","Max":"100","NumDecimals":""}}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_7V5e1i5581koSwu","Element":"SQ","PrimaryAttribute":"QID28","SecondaryAttribute":"Which races\/ethnicities do you identify with?","TertiaryAttribute":null,"Payload":{"QuestionText":"Which races\/ethnicities do you identify with?","DataExportTag":"race","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Which races\/ethnicities do you identify with?","Choices":{"1":{"Display":"White"},"2":{"Display":"Black or African American"},"3":{"Display":"Latino"},"4":{"Display":"Asian"},"5":{"Display":"Other"},"6":{"Display":"American Indian or Alaska Native"},"7":{"Display":"Native Hawaiian or Other Pacific Islander"}},"ChoiceOrder":["1","2","6","3","4","7","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":8,"NextAnswerId":1,"QuestionID":"QID28"}},{"SurveyID":"SV_7V5e1i5581koSwu","Element":"SQ","PrimaryAttribute":"QID29","SecondaryAttribute":"You are invited to take part in a research study about how people make judgments about different...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"max-width: 700px; margin: 0 auto; line-height: 1.5;\">\n\n  <p>\n    You are invited to take part in a research study about how people make judgments about different consumer groups.\n  <\/p>\n\n  <p>\n    <strong>If you agree to participate, you will:<\/strong>\n  <\/p>\n\n  <ul>\n    <li>Answer a few questions<\/li>\n    <li>Have a short text-based conversation with an AI chatbot<\/li>\n    <li>Answer follow-up questions<\/li>\n  <\/ul>\n\n  <p>\n    The study takes approximately <strong>15\u201320 minutes<\/strong>.\n  <\/p>\n\n  <p>\n    Your participation is <strong>voluntary<\/strong>. You may stop at any time without penalty.\n  <\/p>\n\n  <p>\n    Your responses will be kept confidential and analyzed only in aggregate.\n    The chatbot is an AI system, not a real person.\n  <\/p>\n\n  <p>\n    If you have questions about the study, contact:\n    <strong>blira@sas.upenn.edu<\/strong>\n  <\/p>\n\n  <hr style=\"margin: 24px 0;\">\n\n  <p>\n    <strong>To confirm you are at least 18 years old and agree to participate:<\/strong><br>\n    Click <strong>\u201cI agree\u201d<\/strong> below.\n  <\/p>\n\n  <p>\n    <strong>To decline to participate:<\/strong><br>\n    Close this browser tab.\n  <\/p>\n\n<\/div>","DefaultChoices":false,"DataExportTag":"Q29","QuestionID":"QID29","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription